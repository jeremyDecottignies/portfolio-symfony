{% extends 'base.html.twig' %}

{% block title %}{{ project.nom }} — Portfolio Jérémy Decottignies{% endblock %}

{% block body %}

    {# ═══════════════════════════════════════════════════════════
   EN-TÊTE PROJET
═══════════════════════════════════════════════════════════ #}
    <section class="py-5" style="background: var(--bg); position: relative; overflow: hidden;">

        <div aria-hidden="true" style="
        position: absolute; top: -60px; right: -60px;
        width: 320px; height: 320px; border-radius: 50%;
        background: radial-gradient(circle, rgba(var(--accent-rgb),.07) 0%, transparent 70%);
        pointer-events: none;
    "></div>

        <div class="container py-2">

            {# Fil d'Ariane #}
            <nav aria-label="breadcrumb" class="fade-up mb-4">
                <ol class="breadcrumb mb-0" style="font-size: .8rem;">
                    <li class="breadcrumb-item">
                        <a href="{{ path('home') }}" style="color: var(--text-muted);">Accueil</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="{{ path('project_index') }}" style="color: var(--text-muted);">Projets</a>
                    </li>
                    <li class="breadcrumb-item active" style="color: var(--text-muted);">{{ project.nom }}</li>
                </ol>
            </nav>

            <div class="row gy-4 align-items-start">
                <div class="col-lg-8">
                    <span class="tech-badge fade-up mb-3 d-inline-block">Projet</span>
                    <h1 class="fade-up fade-up-delay-1 mb-3" style="font-size: clamp(1.8rem, 4vw, 2.8rem);">
                        {{ project.nom }}
                    </h1>
                    <p class="fade-up fade-up-delay-2 mb-4" style="font-size: 1.05rem; color: var(--text-muted); font-weight: 300; max-width: 580px;">
                        {{ project.courteDescription|striptags }}
                    </p>

                    <div class="fade-up fade-up-delay-3 d-flex flex-wrap gap-2">
                        {% if project.gitUrl %}
                            <a href="{{ project.gitUrl }}" target="_blank" rel="noopener"
                               class="btn btn-primary">
                                Voir sur GitHub →
                            </a>
                        {% endif %}
                        <a href="{{ path('project_index') }}" class="btn btn-outline-primary">
                            ← Retour aux projets
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ═══════════════════════════════════════════════════════════
   IMAGE DU PROJET
═══════════════════════════════════════════════════════════ #}
    {% if project.image %}
        <section style="background: var(--bg-section); padding: 2rem 0;">
            <div class="container">
                <div class="reveal" style="
            border-radius: 1.25rem;
            overflow: hidden;
            border: 1px solid var(--border);
            box-shadow: 0 16px 48px rgba(0,0,0,0.08);
        ">
                    <img src="{{ asset('uploads/images/projects/' ~ project.image) }}"
                         alt="{{ project.nom }}"
                         class="img-fluid d-block w-100"
                         style="max-height: 520px; object-fit: cover;">
                </div>
            </div>
        </section>
    {% endif %}

    {# ═══════════════════════════════════════════════════════════
   CONTENU PRINCIPAL
═══════════════════════════════════════════════════════════ #}
    <section class="py-5" style="background: var(--bg);">
        <div class="container">
            <div class="row g-5">

                {# Description détaillée #}
                <div class="col-lg-8 reveal">
                    <p class="section-label">Description</p>
                    <h2 class="mb-4" style="font-size: 1.5rem;">À propos du projet</h2>

                    <div style="
                    font-size: .95rem;
                    line-height: 1.85;
                    color: var(--text-muted);
                " class="project-content">
                        {{ project.description|raw }}
                    </div>
                </div>

                {# Sidebar infos #}
                <div class="col-lg-4 reveal" style="transition-delay:.1s">
                    <div class="card p-4" style="position: sticky; top: 5rem;">

                        <p class="section-label mb-3">Informations</p>

                        <dl style="font-size: .875rem;">
                            <dt style="color: var(--text-muted); font-weight: 400; margin-bottom: .2rem;">Référence</dt>
                            <dd style="font-weight: 600; margin-bottom: 1rem;">#{{ '%03d'|format(project.id) }}</dd>

                            {% if project.gitUrl %}
                                <dt style="color: var(--text-muted); font-weight: 400; margin-bottom: .2rem;">Dépôt</dt>
                                <dd style="margin-bottom: 1rem;">
                                    <a href="{{ project.gitUrl }}" target="_blank" rel="noopener"
                                       style="color: var(--accent); font-size: .875rem; word-break: break-all;">
                                        GitHub →
                                    </a>
                                </dd>
                            {% endif %}
                        </dl>

                        <hr style="border-color: var(--border); margin: .5rem 0 1rem;">

                        <p style="font-size: .8rem; color: var(--text-muted); margin: 0;">
                            Retrouve tous mes projets sur la
                            <a href="{{ path('project_index') }}" style="color: var(--accent);">page projets</a>.
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </section>

    {# ═══════════════════════════════════════════════════════════
   STYLES POUR LE CONTENU RICH TEXT
═══════════════════════════════════════════════════════════ #}
    <style>
        .project-content h2,
        .project-content h3 {
            font-family: var(--font-display);
            font-weight: 700;
            color: var(--text);
            margin-top: 2rem;
            margin-bottom: .75rem;
        }

        .project-content h2 { font-size: 1.3rem; }
        .project-content h3 { font-size: 1.1rem; }

        .project-content p { margin-bottom: 1.1rem; }

        .project-content ul,
        .project-content ol {
            padding-left: 1.4rem;
            margin-bottom: 1.1rem;
        }

        .project-content li { margin-bottom: .35rem; }

        .project-content a { color: var(--accent); }

        .project-content code {
            font-size: .85rem;
            padding: .15rem .4rem;
            border-radius: .35rem;
            background: rgba(var(--accent-rgb), .08);
            color: var(--accent);
        }

        .project-content pre {
            background: var(--bg-section);
            border: 1px solid var(--border);
            border-radius: .75rem;
            padding: 1.25rem;
            overflow-x: auto;
            font-size: .85rem;
        }

        .breadcrumb-item + .breadcrumb-item::before { color: var(--text-muted); }
    </style>

{% endblock %}
