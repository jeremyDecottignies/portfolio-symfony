{% extends 'base.html.twig' %}

{% block title %}{{ project.nom }} — Portfolio Jérémy Decottignies{% endblock %}

{% block body %}

    {# ═══════════════════════════════════════════════════════════
   EN-TÊTE PROJET
═══════════════════════════════════════════════════════════ #}
    <section class="py-5" style="background: var(--bg); position: relative; overflow: hidden;">

        <div aria-hidden="true" style="
        position: absolute; top: -60px; right: -60px;
        width: 320px; height: 320px; border-radius: 50%;
        background: radial-gradient(circle, rgba(var(--accent-rgb),.07) 0%, transparent 70%);
        pointer-events: none;
    "></div>

        <div class="container py-2">

            <nav aria-label="breadcrumb" class="fade-up mb-4">
                <ol class="breadcrumb mb-0" style="font-size: .8rem;">
                    <li class="breadcrumb-item">
                        <a href="{{ path('home') }}" style="color: var(--text-muted);">Accueil</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="{{ path('project_index') }}" style="color: var(--text-muted);">Projets</a>
                    </li>
                    <li class="breadcrumb-item active" style="color: var(--text-muted);">{{ project.nom }}</li>
                </ol>
            </nav>

            <div class="row gy-4 align-items-start">
                <div class="col-lg-8">
                    <span class="tech-badge fade-up mb-3 d-inline-block">Projet</span>
                    <h1 class="fade-up fade-up-delay-1 mb-3" style="font-size: clamp(1.8rem, 4vw, 2.8rem);">
                        {{ project.nom }}
                    </h1>
                    <p class="fade-up fade-up-delay-2 mb-4" style="font-size: 1.05rem; color: var(--text-muted); font-weight: 300; max-width: 580px;">
                        {{ project.courteDescription|striptags }}
                    </p>

                    <div class="fade-up fade-up-delay-3 d-flex flex-wrap gap-2">
                        {% if project.gitUrl %}
                            <a href="{{ project.gitUrl }}" target="_blank" rel="noopener" class="btn btn-primary">
                                Voir sur GitHub →
                            </a>
                        {% endif %}
                        {% if project.pdffile %}
                            <a href="{{ asset('uploads/pdf/projects/' ~ project.pdffile) }}"
                               target="_blank" rel="noopener"
                               class="btn btn-outline-primary">
                                📄 Voir le PDF
                            </a>
                        {% endif %}
                        <a href="{{ path('project_index') }}" class="btn btn-outline-primary">
                            ← Retour aux projets
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ═══════════════════════════════════════════════════════════
   IMAGES DU PROJET
═══════════════════════════════════════════════════════════ #}

    {% set allImages = [] %}
    {% if project.image %}
        {% set allImages = allImages|merge([{src: 'uploads/images/projects/' ~ project.image, alt: project.nom ~ ' - image principale'}]) %}
    {% endif %}
    {% for img in project.projectImages %}
        {% set allImages = allImages|merge([{src: 'uploads/images/projects/' ~ img.filename, alt: project.nom ~ ' - image ' ~ loop.index}]) %}
    {% endfor %}

    {% if allImages|length > 0 %}
        <section style="background: var(--bg-section); padding: 2rem 0;">
            <div class="container">

                {% if project.displayMode == 'comparison' %}

                    <div class="reveal mb-3">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="tech-badge">Avant / Après</span>
                            <span style="font-size: .8rem; color: var(--text-muted);">{{ allImages|length }} captures</span>
                        </div>

                        <div style="
                    display: grid;
                    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
                    gap: 1rem;
                ">
                            {% for img in allImages %}
                                <div style="
                            background: var(--bg);
                            border: 1px solid var(--border);
                            border-radius: 1rem;
                            overflow: hidden;
                            display: flex;
                            flex-direction: column;
                        ">
                                    <div style="
                                padding: .4rem .9rem;
                                font-size: .72rem;
                                font-weight: 600;
                                font-family: var(--font-mono, monospace);
                                background: rgba(var(--accent-rgb), .08);
                                color: var(--accent);
                                border-bottom: 1px solid var(--border);
                            ">
                                        {% if loop.first %}Avant
                                        {% elseif loop.last and allImages|length == 2 %}Après
                                        {% else %}Étape {{ loop.index }}
                                        {% endif %}
                                    </div>
                                    <div style="
                                flex: 1;
                                display: flex;
                                align-items: center;
                                justify-content: center;
                                padding: .75rem;
                                min-height: 280px;
                                background: var(--bg);
                            ">
                                        <img src="{{ asset(img.src) }}"
                                             alt="{{ img.alt }}"
                                             style="max-width: 100%; max-height: 400px; object-fit: contain; border-radius: .5rem;"
                                             onclick="openLightbox('{{ asset(img.src) }}', '{{ img.alt }}')"
                                             class="project-img-clickable">
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>

                {% else %}

                    <div class="reveal">
                        {% if allImages|length == 1 %}
                            <div style="
                        border-radius: 1.25rem;
                        overflow: hidden;
                        border: 1px solid var(--border);
                        box-shadow: 0 16px 48px rgba(0,0,0,0.08);
                        background: var(--bg);
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        padding: 1rem;
                        min-height: 300px;
                    ">
                                <img src="{{ asset(allImages[0].src) }}"
                                     alt="{{ allImages[0].alt }}"
                                     style="max-width: 100%; max-height: 500px; object-fit: contain; border-radius: .75rem;"
                                     onclick="openLightbox('{{ asset(allImages[0].src) }}', '{{ allImages[0].alt }}')"
                                     class="project-img-clickable">
                            </div>

                        {% else %}
                            <div style="
                        display: grid;
                        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
                        gap: 1rem;
                    ">
                                {% for img in allImages %}
                                    <div style="
                                background: var(--bg);
                                border: 1px solid var(--border);
                                border-radius: 1rem;
                                overflow: hidden;
                                display: flex;
                                align-items: center;
                                justify-content: center;
                                padding: .75rem;
                                min-height: 220px;
                                transition: border-color .2s, transform .2s;
                            "
                                         onmouseover="this.style.borderColor='rgba(var(--accent-rgb),.4)';this.style.transform='translateY(-3px)'"
                                         onmouseout="this.style.borderColor='var(--border)';this.style.transform='none'">
                                        <img src="{{ asset(img.src) }}"
                                             alt="{{ img.alt }}"
                                             style="max-width: 100%; max-height: 300px; object-fit: contain; border-radius: .5rem;"
                                             onclick="openLightbox('{{ asset(img.src) }}', '{{ img.alt }}')"
                                             class="project-img-clickable">
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                {% endif %}

            </div>
        </section>

        {# Lightbox #}
        <div id="lightbox" style="
    display: none;
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,.92);
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
" onclick="closeLightbox()">
            <img id="lightbox-img" src="" alt=""
                 style="max-width: 90vw; max-height: 90vh; object-fit: contain; border-radius: .75rem;">
            <button onclick="closeLightbox()" style="
        position: absolute; top: 1.5rem; right: 1.5rem;
        background: rgba(255,255,255,.1);
        border: 1px solid rgba(255,255,255,.2);
        color: #fff;
        width: 40px; height: 40px;
        border-radius: 50%;
        font-size: 1.2rem;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
    ">✕</button>
        </div>

    {% endif %}

    {# ═══════════════════════════════════════════════════════════
   CONTENU PRINCIPAL
═══════════════════════════════════════════════════════════ #}
    <section class="py-5" style="background: var(--bg);">
        <div class="container">
            <div class="row g-5">

                <div class="col-lg-8 reveal">
                    <p class="section-label">Description</p>
                    <h2 class="mb-4" style="font-size: 1.5rem;">À propos du projet</h2>
                    <div class="project-content" style="font-size: .95rem; line-height: 1.85; color: var(--text-muted);">
                        {{ project.description|raw }}
                    </div>
                </div>

                <div class="col-lg-4 reveal" style="transition-delay:.1s">
                    <div class="card p-4" style="position: sticky; top: 5rem;">

                        <p class="section-label mb-3">Informations</p>

                        <dl style="font-size: .875rem;">
                            <dt style="color: var(--text-muted); font-weight: 400; margin-bottom: .2rem;">Référence</dt>
                            <dd style="font-weight: 600; margin-bottom: 1rem;">#{{ '%03d'|format(project.id) }}</dd>

                            {% if project.gitUrl %}
                                <dt style="color: var(--text-muted); font-weight: 400; margin-bottom: .2rem;">Dépôt</dt>
                                <dd style="margin-bottom: 1rem;">
                                    <a href="{{ project.gitUrl }}" target="_blank" rel="noopener"
                                       style="color: var(--accent); font-size: .875rem; word-break: break-all;">
                                        GitHub →
                                    </a>
                                </dd>
                            {% endif %}

                            {% if project.pdfFile %}
                                <dt style="color: var(--text-muted); font-weight: 400; margin-bottom: .2rem;">Document</dt>
                                <dd style="margin-bottom: 1rem;">
                                    <a href="{{ asset('uploads/pdf/projects/' ~ project.pdfFile) }}"
                                       target="_blank" rel="noopener"
                                       style="color: var(--accent); font-size: .875rem;">
                                        📄 Télécharger le PDF →
                                    </a>
                                </dd>
                            {% endif %}

                            {% if allImages|length > 0 %}
                                <dt style="color: var(--text-muted); font-weight: 400; margin-bottom: .2rem;">Photos</dt>
                                <dd style="margin-bottom: 1rem;">
                                    <span class="tech-badge">{{ allImages|length }} image(s)</span>
                                </dd>
                            {% endif %}

                            {% if project.competences is defined and project.competences|length > 0 %}
                                <dt style="color: var(--text-muted); font-weight: 400; margin-bottom: .5rem;">Compétences BTS SIO</dt>
                                <dd style="margin-bottom: 1rem;">
                                    <div class="d-flex flex-column gap-2">
                                        {% for competence in project.competences %}
                                            <div style="
                                            display: flex; align-items: center; gap: .6rem;
                                            padding: .4rem .75rem;
                                            border-radius: .6rem;
                                            background: rgba(var(--accent-rgb),.06);
                                            border: 1px solid rgba(var(--accent-rgb),.15);
                                        ">
                                                <span style="font-size: .72rem; font-weight: 700; color: var(--accent); min-width: 24px;">{{ competence.code }}</span>
                                                <span style="font-size: .78rem; color: var(--text-muted);">{{ competence.libelle }}</span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </dd>
                            {% endif %}
                        </dl>

                        <hr style="border-color: var(--border); margin: .5rem 0 1rem;">

                        <p style="font-size: .8rem; color: var(--text-muted); margin: 0;">
                            Retrouve tous mes projets sur la
                            <a href="{{ path('project_index') }}" style="color: var(--accent);">page projets</a>.
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <style>
        .project-img-clickable { cursor: zoom-in; transition: transform .2s; }
        .project-img-clickable:hover { transform: scale(1.02); }

        .project-content h2,
        .project-content h3 {
            font-family: var(--font-display);
            font-weight: 700; color: var(--text);
            margin-top: 2rem; margin-bottom: .75rem;
        }

        .project-content h2 { font-size: 1.3rem; }
        .project-content h3 { font-size: 1.1rem; }
        .project-content p { margin-bottom: 1.1rem; }

        .project-content ul,
        .project-content ol { padding-left: 1.4rem; margin-bottom: 1.1rem; }

        .project-content li { margin-bottom: .35rem; }
        .project-content a { color: var(--accent); }

        .project-content code {
            font-size: .85rem; padding: .15rem .4rem;
            border-radius: .35rem;
            background: rgba(var(--accent-rgb), .08);
            color: var(--accent);
        }

        .project-content pre {
            background: var(--bg-section);
            border: 1px solid var(--border);
            border-radius: .75rem;
            padding: 1.25rem; overflow-x: auto; font-size: .85rem;
        }

        .breadcrumb-item + .breadcrumb-item::before { color: var(--text-muted); }
    </style>

    <script>
        function openLightbox(src, alt) {
            const lb = document.getElementById('lightbox');
            const img = document.getElementById('lightbox-img');
            img.src = src; img.alt = alt;
            lb.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
            document.getElementById('lightbox').style.display = 'none';
            document.body.style.overflow = '';
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeLightbox();
        });
    </script>

{% endblock %}
