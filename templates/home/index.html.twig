{% extends 'base.html.twig' %}

{% block title %}Accueil — Portfolio Jérémy Decottignies{% endblock %}

{% block body %}

    {# ═══════════════════════════════════════════════════════════
   HERO
═══════════════════════════════════════════════════════════ #}
    <section class="py-5" style="background: var(--bg); position: relative; overflow: hidden;">

        {# Cercles décoratifs en fond #}
        <div aria-hidden="true" style="
        position: absolute; top: -80px; right: -80px;
        width: 420px; height: 420px; border-radius: 50%;
        background: radial-gradient(circle, rgba(var(--accent-rgb),.07) 0%, transparent 70%);
        pointer-events: none;
    "></div>
        <div aria-hidden="true" style="
        position: absolute; bottom: -60px; left: 5%;
        width: 260px; height: 260px; border-radius: 50%;
        background: radial-gradient(circle, rgba(var(--accent-rgb),.04) 0%, transparent 70%);
        pointer-events: none;
    "></div>

        <div class="container py-4">
            <div class="row align-items-center gy-4">
                <div class="col-lg-8">

                    {# Étiquette animée #}
                    <div class="fade-up mb-3" style="
                    display: inline-flex; align-items: center; gap: .5rem;
                    font-size: .75rem; font-weight: 600;
                    color: var(--accent);
                    background: rgba(var(--accent-rgb),.08);
                    border: 1px solid rgba(var(--accent-rgb),.15);
                    border-radius: 999px; padding: .3rem .9rem;
                ">
                    <span style="
                        width: 7px; height: 7px; border-radius: 50%;
                        background: var(--accent);
                        animation: heroPulse 2s infinite;
                    "></span>
                        Disponible — BTS SIO option SLAM
                    </div>

                    <h1 class="fade-up fade-up-delay-1 mb-3" style="font-size: clamp(2rem, 5vw, 3.2rem);">
                        Développeur web<br>
                        <span style="color: var(--accent);">Symfony &amp; PHP</span>
                    </h1>

                    <p class="fade-up fade-up-delay-2 mb-4" style="font-size: 1.05rem; color: var(--text-muted); max-width: 520px; font-weight: 300;">
                        Je conçois des applications web robustes, lisibles et bien structurées.
                        Passionné par la logique back-end et les interfaces qui ont du caractère.
                    </p>

                    <div class="fade-up fade-up-delay-3 d-flex flex-wrap gap-2 mb-4">
                        <a href="{{ path('project_index') }}" class="btn btn-primary">
                            Voir mes projets
                        </a>
                        <a href="{{ path('contact') }}" class="btn btn-outline-primary">
                            Me contacter
                        </a>
                    </div>

                    {# Stack chips #}
                    <div class="fade-up fade-up-delay-4 d-flex flex-wrap gap-2">
                        {% set stack = ['PHP 8', 'Symfony 6', 'MySQL', 'Twig', 'Bootstrap 5', 'Git', 'Doctrine ORM', 'Java', 'Kotlin'] %}
                        {% for tech in stack %}
                            <span class="tech-badge">{{ tech }}</span>
                        {% endfor %}
                    </div>

                </div>
            </div>
        </div>
    </section>

    <style>
        @keyframes heroPulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50%       { opacity: 0.5; transform: scale(1.3); }
        }
    </style>

    {# ═══════════════════════════════════════════════════════════
   PROJETS RÉCENTS
═══════════════════════════════════════════════════════════ #}
    <section class="py-5 section-alt">
        <div class="container">

            <div class="d-flex align-items-baseline justify-content-between mb-4">
                <div>
                    <p class="section-label">Travaux récents</p>
                    <h2 class="mb-0" style="font-size: 1.75rem;">Derniers projets</h2>
                </div>
                <a href="{{ path('project_index') }}" class="btn btn-outline-primary btn-sm d-none d-md-inline-flex">
                    Tous les projets →
                </a>
            </div>

            <div class="row g-4">
                {% for project in projects %}
                    <div class="col-md-6 col-lg-4 reveal" style="transition-delay: {{ loop.index0 * 0.08 }}s;">
                        <div class="card h-100">
                            <div class="card-body d-flex flex-column p-4">

                                {# Tag catégorie (optionnel, adapte selon ton entité) #}
                                {% if project.categorie is defined and project.categorie %}
                                    <span class="tech-badge mb-3 align-self-start">{{ project.categorie }}</span>
                                {% else %}
                                    <span class="tech-badge mb-3 align-self-start">Projet</span>
                                {% endif %}

                                <h3 class="card-title mb-2">{{ project.nom }}</h3>

                                <p class="text-muted mb-3" style="font-size: .9rem; flex: 1;">
                                    {{ project.courteDescription|striptags|slice(0, 120) ~ '...' }}
                                </p>

                                {# Technologies (si tu as une relation technologies sur ton entité) #}
                                {% if project.technologies is defined and project.technologies|length %}
                                    <div class="d-flex flex-wrap gap-1 mb-3">
                                        {% for tech in project.technologies|slice(0, 4) %}
                                            <span style="
                                            font-size: .7rem; font-weight: 500;
                                            padding: .2rem .6rem;
                                            border-radius: 999px;
                                            background: var(--bg-section);
                                            color: var(--text-muted);
                                            border: 1px solid var(--border);
                                        ">{{ tech }}</span>
                                        {% endfor %}
                                    </div>
                                {% endif %}

                                <a href="{{ path('project_show', { id: project.id }) }}"
                                   class="btn btn-outline-primary btn-sm align-self-start mt-auto">
                                    Voir le projet →
                                </a>

                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <p class="text-muted">Aucun projet pour l'instant. Revenez bientôt !</p>
                    </div>
                {% endfor %}
            </div>

            <div class="text-center mt-4 d-md-none">
                <a href="{{ path('project_index') }}" class="btn btn-outline-primary">
                    Tous les projets →
                </a>
            </div>

        </div>
    </section>

    {# ═══════════════════════════════════════════════════════════
   MINI À PROPOS / CTA
═══════════════════════════════════════════════════════════ #}
    <section class="py-5" style="background: var(--bg);">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8 text-center reveal">
                    <p class="section-label justify-content-center">À propos</p>
                    <h2 class="mb-3" style="font-size: 1.75rem;">
                        Étudiant passionné,<br>en quête d'alternance
                    </h2>
                    <p class="text-muted mx-auto mb-4" style="max-width: 500px; font-weight: 300;">
                        En BTS SIO option SLAM, je me forme au développement web full-stack
                        avec une appétence particulière pour Symfony, les architectures propres
                        et les interfaces soignées.
                    </p>
                    <div class="d-flex justify-content-center gap-3 flex-wrap">
                        <a href="{{ path('about') }}" class="btn btn-primary">En savoir plus</a>
                        <a href="{{ path('contact') }}" class="btn btn-outline-primary">Prendre contact</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

{% endblock %}
