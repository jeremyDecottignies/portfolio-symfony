    <script>
        // Progress bar
        const vBar = document.getElementById('veille-progress');
        window.addEventListener('scroll', () => {
            const h = document.documentElement;
            const pct = (window.scrollY / (h.scrollHeight - h.clientHeight)) * 100;
            if (vBar) vBar.style.width = pct + '%';
        }, { passive: true });

        // Scroll reveal
        const vIo = new IntersectionObserver((entries) => {
            entries.forEach((e, i) => {
                if (e.isIntersecting) {
                    setTimeout(() => e.target.classList.add('visible'), i * 80);
                    vIo.unobserve(e.target);
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.v-tl-item, .v-tech-card, .v-mstat').forEach(el => vIo.observe(el));
    </script>

