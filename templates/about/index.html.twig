{% extends 'base.html.twig' %}

{% block title %}À propos — Jérémy Decottignies{% endblock %}

{% block body %}

    {# ═══════════════════════════════════════════════════════════
   HERO À PROPOS
═══════════════════════════════════════════════════════════ #}
    <section class="py-5" style="background: var(--bg); position: relative; overflow: hidden;">

        <div aria-hidden="true" style="
        position: absolute; top: -60px; right: -60px;
        width: 350px; height: 350px; border-radius: 50%;
        background: radial-gradient(circle, rgba(var(--accent-rgb),.07) 0%, transparent 70%);
        pointer-events: none;
    "></div>

        <div class="container py-3">
            <div class="row align-items-center gy-5">

                <div class="col-md-3 text-center fade-up">
                    <div style="
                    width: 140px; height: 140px;
                    border-radius: 50%;
                    background: linear-gradient(135deg, rgba(var(--accent-rgb),.15), rgba(var(--accent-rgb),.05));
                    border: 2px solid rgba(var(--accent-rgb),.2);
                    display: inline-flex; align-items: center; justify-content: center;
                    font-family: var(--font-display); font-size: 3rem; font-weight: 800;
                    color: var(--accent);
                ">J</div>
                </div>

                <div class="col-md-9">
                    <p class="section-label fade-up">À propos</p>
                    <h1 class="fade-up fade-up-delay-1 mb-3" style="font-size: clamp(1.8rem, 4vw, 2.6rem);">
                        Jérémy Decottignies
                    </h1>
                    <p class="fade-up fade-up-delay-2 mb-4" style="font-size: 1.05rem; color: var(--text-muted); max-width: 560px; font-weight: 300;">
                        Étudiant en BTS SIO option SLAM au Lycée la Colinière de Nantes. Passionné par
                        le développement web, j'aime construire des applications robustes et lisibles
                        avec Symfony, PHP et des interfaces soignées.
                    </p>
                    <div class="fade-up fade-up-delay-3 d-flex flex-wrap gap-2">
                        <a href="{{ asset('cv/CV.pdf') }}" target="_blank" class="btn btn-primary">
                            Télécharger mon CV
                        </a>
                        <a href="{{ path('contact') }}" class="btn btn-outline-primary">Me contacter</a>
                    </div>
                </div>

            </div>
        </div>
    </section>

    {# ═══════════════════════════════════════════════════════════
   COMPÉTENCES
═══════════════════════════════════════════════════════════ #}
    <section class="py-5 section-alt">
        <div class="container">

            <p class="section-label reveal">Savoir-faire</p>
            <h2 class="mb-4 reveal" style="font-size: 1.75rem;">Compétences</h2>

            <div class="row g-4">

                <div class="col-md-4 reveal">
                    <div class="card h-100 p-4">
                        <div class="mb-3" style="
                        width: 44px; height: 44px; border-radius: .75rem;
                        background: rgba(var(--accent-rgb),.1);
                        display: flex; align-items: center; justify-content: center;
                        font-size: 1.3rem;
                    ">💻</div>
                        <h3 class="card-title mb-3" style="font-size: 1rem;">Développement</h3>
                        <div class="d-flex flex-wrap gap-2">
                            {% set devSkills = ['HTML / CSS', 'JavaScript', 'PHP 8', 'Symfony 6', 'SQL / MySQL', 'Twig', 'Doctrine ORM'] %}
                            {% for s in devSkills %}
                                <span class="tech-badge">{{ s }}</span>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <div class="col-md-4 reveal" style="transition-delay:.08s">
                    <div class="card h-100 p-4">
                        <div class="mb-3" style="
                        width: 44px; height: 44px; border-radius: .75rem;
                        background: rgba(var(--accent-rgb),.1);
                        display: flex; align-items: center; justify-content: center;
                        font-size: 1.3rem;
                    ">🛠️</div>
                        <h3 class="card-title mb-3" style="font-size: 1rem;">Outils &amp; Méthodes</h3>
                        <div class="d-flex flex-wrap gap-2">
                            {% set toolSkills = ['Git / GitHub', 'VS Code', 'PhpStorm', 'Scrum', 'Kanban', 'Documentation'] %}
                            {% for s in toolSkills %}
                                <span class="tech-badge">{{ s }}</span>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <div class="col-md-4 reveal" style="transition-delay:.16s">
                    <div class="card h-100 p-4">
                        <div class="mb-3" style="
                        width: 44px; height: 44px; border-radius: .75rem;
                        background: rgba(var(--accent-rgb),.1);
                        display: flex; align-items: center; justify-content: center;
                        font-size: 1.3rem;
                    ">🎯</div>
                        <h3 class="card-title mb-3" style="font-size: 1rem;">Objectifs</h3>
                        <ul class="mb-0" style="padding-left: 1.1rem; color: var(--text-muted); font-size: .9rem;">
                            <li class="mb-1">Continuer dans le développement web</li>
                            <li class="mb-1">Se spécialiser sur Symfony / API Platform</li>
                            <li class="mb-1">Travailler sur des projets concrets</li>
                            <li>Évoluer vers un Bachelor ou BUT</li>
                        </ul>
                    </div>
                </div>

            </div>
        </div>
    </section>

    {# ═══════════════════════════════════════════════════════════
   EXPÉRIENCES
═══════════════════════════════════════════════════════════ #}
    <section class="py-5" style="background: var(--bg);">
        <div class="container">

            <p class="section-label reveal">Parcours professionnel</p>
            <h2 class="mb-4 reveal" style="font-size: 1.75rem;">Expériences</h2>

            {% if experiences is not empty %}
                <div class="timeline">
                    {% for exp in experiences %}
                        <div class="timeline-item mb-4 ps-3 reveal" style="transition-delay: {{ loop.index0 * 0.1 }}s;">
                            <div class="timeline-dot"></div>

                            <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                <h5 class="mb-0" style="font-size: 1rem;">{{ exp.titre }}</h5>
                                <span class="tech-badge">{{ exp.entreprise }}</span>
                                {% if not exp.dateFin %}
                                    <span style="
                                    font-size: .7rem; font-weight: 600; padding: .2rem .6rem;
                                    border-radius: 999px;
                                    background: rgba(22,163,74,.12); color: #16a34a;
                                    border: 1px solid rgba(22,163,74,.2);
                                ">En cours</span>
                                {% endif %}
                            </div>

                            <p class="mb-2" style="font-size: .8rem; color: var(--text-muted);">
                                {{ exp.lieu }} · {{ exp.type }} ·
                                {{ exp.dateDebut|date('m/Y') }}
                                {% if exp.dateFin %} – {{ exp.dateFin|date('m/Y') }}{% endif %}
                            </p>

                            {# Courte description #}
                            {% if exp.courteDescription %}
                                <p class="mb-2" style="font-size: .9rem; color: var(--text-muted); line-height: 1.65;">
                                    {{ exp.courteDescription }}
                                </p>
                            {% endif %}

                            {# Compétences BTS SIO #}
                            {% if exp.competences|length > 0 %}
                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    {% for competence in exp.competences %}
                                        <span style="
                                        font-size: .7rem; font-weight: 600;
                                        padding: .2rem .65rem;
                                        border-radius: 999px;
                                        background: rgba(var(--accent-rgb),.08);
                                        color: var(--accent);
                                        border: 1px solid rgba(var(--accent-rgb),.2);
                                    ">{{ competence.code }} — {{ competence.libelle }}</span>
                                    {% endfor %}
                                </div>
                            {% endif %}

                            {# Lien vers la page détail #}
                            <a href="{{ path('experience_show', {id: exp.id}) }}"
                               class="btn btn-outline-primary btn-sm">
                                Voir le détail →
                            </a>

                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-muted">Pas encore d'expérience renseignée.</p>
            {% endif %}

        </div>
    </section>

    {# ═══════════════════════════════════════════════════════════
   PARCOURS SCOLAIRE
═══════════════════════════════════════════════════════════ #}
    <section class="py-5 section-alt">
        <div class="container">

            <p class="section-label reveal">Formation</p>
            <h2 class="mb-4 reveal" style="font-size: 1.75rem;">Parcours scolaire</h2>

            {% if educations is not empty %}
                <div class="timeline">
                    {% for edu in educations %}
                        <div class="timeline-item mb-4 ps-3 reveal" style="transition-delay: {{ loop.index0 * 0.1 }}s;">
                            <div class="timeline-dot"></div>

                            <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                <h5 class="mb-0" style="font-size: 1rem;">{{ edu.intitule }}</h5>
                                <span class="tech-badge">{{ edu.etablissement }}</span>
                                {% if not edu.dateFin %}
                                    <span style="
                                    font-size: .7rem; font-weight: 600; padding: .2rem .6rem;
                                    border-radius: 999px;
                                    background: rgba(22,163,74,.12); color: #16a34a;
                                    border: 1px solid rgba(22,163,74,.2);
                                ">En cours</span>
                                {% endif %}
                            </div>

                            <p class="mb-2" style="font-size: .8rem; color: var(--text-muted);">
                                {{ edu.lieu }}
                                {% if edu.niveau %} · {{ edu.niveau }}{% endif %} ·
                                {{ edu.dateDebut|date('Y') }}
                                {% if edu.dateFin %} – {{ edu.dateFin|date('Y') }}{% endif %}
                            </p>

                            {% if edu.description %}
                                <div class="about-content" style="font-size: .875rem; color: var(--text-muted); line-height: 1.75;">
                                    {{ edu.description|raw }}
                                </div>
                            {% endif %}

                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-muted">Parcours scolaire à venir.</p>
            {% endif %}

        </div>
    </section>

    {# ═══════════════════════════════════════════════════════════
   CTA CONTACT
═══════════════════════════════════════════════════════════ #}
    <section class="py-5" style="background: var(--bg);">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-7 text-center reveal">
                    <h2 class="mb-3" style="font-size: 1.75rem;">
                        Envie de collaborer ?
                    </h2>
                    <p class="text-muted mb-4" style="font-weight: 300;">
                        Je suis ouvert aux opportunités d'alternance, de stage ou simplement à
                        un échange autour d'un projet.
                    </p>
                    <a href="{{ path('contact') }}" class="btn btn-primary btn-lg">
                        Me contacter →
                    </a>
                </div>
            </div>
        </div>
    </section>

    <style>
        .about-content h3 {
            font-family: var(--font-display);
            font-weight: 700;
            font-size: 1rem;
            color: var(--text);
            margin-top: 1.25rem;
            margin-bottom: .5rem;
        }

        .about-content ul,
        .about-content ol {
            padding-left: 1.2rem;
            margin-bottom: .75rem;
        }

        .about-content li { margin-bottom: .25rem; }
        .about-content p { margin-bottom: .75rem; }

        .about-content strong {
            color: var(--text);
            font-weight: 600;
        }

        .about-content code {
            font-size: .82rem;
            padding: .15rem .4rem;
            border-radius: .35rem;
            background: rgba(var(--accent-rgb), .08);
            color: var(--accent);
        }
    </style>

{% endblock %}
